# Supabase – hittas under Project Settings > API i Supabase-dashboarden
NEXT_PUBLIC_SUPABASE_URL=https://ditt-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-nyckel
SUPABASE_SERVICE_ROLE_KEY=din-service-role-nyckel

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Bas-URL för appen (används i inbjudningslänkar)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E-postutskick av inbjudningar via Resend (valfritt – utan nyckel kopierar
# läraren inbjudningslänken manuellt)
RESEND_API_KEY=
EMAIL_FROM="NO-provplattform <inbjudan@din-doman.se>"
